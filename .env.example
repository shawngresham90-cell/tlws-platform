# ============================================================
# TLWS Platform — Environment Template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# --- Supabase (public — safe to expose in browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://cgvxwvymkembftznhcdl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here

# --- Supabase (server-only — Edge Functions / server actions ONLY) ---
# Pull from Supabase dashboard > Project Settings > API. Never ships to browser.
# Used for privileged writes (Edge Functions) that bypass RLS. NOT used by the
# login flow — auth runs on the anon key + user session cookies.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (form spam protection — added in later milestone) ---
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Stripe (gated on EIN -> bank -> Stripe; added in Founders milestone) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://truckinglifewithshawn.com

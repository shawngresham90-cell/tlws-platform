# ============================================================
# TLWS Platform — Environment Template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# --- Supabase (public — safe to expose in browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://cgvxwvymkembftznhcdl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_key_here

# --- Supabase (server-only — route handlers / Edge Functions ONLY) ---
# Bypasses RLS. Performs the writes anon is forbidden from. NEVER ships to the
# browser. Not used by the login flow (auth runs on the anon key + cookies).
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare Turnstile (form spam protection) ---
# Public site key goes in the form (NEXT_PUBLIC_ so it reaches the browser);
# secret verifies server-side. If the secret is unset: dev SKIPS verification
# (with a warning); production FAILS CLOSED.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Resend email (DORMANT until EMAIL_SENDING_ENABLED=true) ---
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_SENDING_ENABLED=false

# --- Twilio SMS (DORMANT until SMS_SENDING_ENABLED=true) ---
# TCPA: never send without recorded consent. Sending stays off this milestone.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_SENDING_ENABLED=false

# --- Stripe (placeholder; gated on EIN -> bank -> Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- On-demand revalidation (shared secret for trusted callers) ---
REVALIDATE_SECRET=

# --- Admin dashboard (Milestone 10 — server-only, protects /admin) ---
# Shared password to sign in at /admin/login.
ADMIN_PASSWORD=
# Random secret that signs the admin session cookie (e.g. `openssl rand -hex 32`).
# Both must be set or /admin is inaccessible (fails closed).
ADMIN_SESSION_SECRET=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://truckinglifewithshawn.com

# --- Trip Planner live providers (server-only; both fail-soft when unset) ---
# EIA open data (free key: eia.gov/opendata) — regional diesel prices.
EIA_API_KEY=
# HERE Base Plan key (free: platform.here.com) — powers BOTH live truck-legal
# routing (Routing API v8) AND free-text origin/destination geocoding
# (Geocoding & Search v7). One key, one shared free tier. Server-side ONLY;
# never expose in the browser.
HERE_API_KEY=

# --- Plausible Analytics (cookieless, optional) ---
# Set to the site's domain (e.g. truckinglifewithshawn.com) to enable
# analytics. Leave unset to ship zero analytics bytes (all trackEvent calls
# no-op safely). This is a public value, not a secret.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
